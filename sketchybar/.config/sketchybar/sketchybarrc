#!/usr/bin/env bash
# omakase-mac — SketchyBar configuration
# A minimal, keyboard-centric status bar focused on AeroSpace workspaces.
# Theme: Catppuccin Mocha (matches Ghostty / tmux).
# Docs: https://felixkratz.github.io/SketchyBar/

PLUGIN_DIR="$CONFIG_DIR/plugins"

# --- Catppuccin Mocha palette (0xAARRGGBB) ---
BASE=0xff1e1e2e        # bar background
TEXT=0xffcdd6f4        # default foreground
BLUE=0xff89b4fa        # focused workspace highlight
SURFACE0=0xff313244    # subtle fill

# --- Bar ---
sketchybar --bar \
  height=32 \
  position=top \
  color=$BASE \
  padding_left=8 \
  padding_right=8 \
  corner_radius=0 \
  sticky=on

# --- Item defaults ---
default=(
  icon.font="0xProto Nerd Font:Bold:14.0"
  icon.color=$TEXT
  label.font="0xProto Nerd Font:Bold:13.0"
  label.color=$TEXT
  padding_left=4
  padding_right=4
  background.corner_radius=6
  background.height=22
)
sketchybar --default "${default[@]}"

# --- Workspace indicators (left) ---
# AeroSpace fires `aerospace_workspace_change` on every switch (see aerospace.toml).
# Each item highlights when its workspace is focused; clicking jumps to it.
sketchybar --add event aerospace_workspace_change

for sid in $(aerospace list-workspaces --all); do
  sketchybar --add item space.$sid left \
    --subscribe space.$sid aerospace_workspace_change \
    --set space.$sid \
      icon="$sid" \
      icon.padding_left=10 \
      icon.padding_right=10 \
      background.color=$SURFACE0 \
      background.drawing=off \
      click_script="aerospace workspace $sid" \
      script="$PLUGIN_DIR/aerospace.sh $sid"
done

# --- Clock (right) — example module; add battery/cpu/etc. alongside it ---
sketchybar --add item clock right \
  --set clock \
    update_freq=10 \
    icon=󰥔 \
    icon.padding_right=6 \
    script="$PLUGIN_DIR/clock.sh" \
  --subscribe clock system_woke

# --- Finalize ---
sketchybar --update
