# omakase-mac — Ghostty configuration
# Docs: https://ghostty.org/docs/config

# --- Appearance ---
theme = catppuccin-mocha
font-family = "0xProto Nerd Font"
font-size = 14
window-padding-x = 8
window-padding-y = 8
cursor-style = block
cursor-style-blink = false
background-opacity = 1.0
macos-titlebar-style = tabs

# --- Behavior ---
# Map the left Option key to Alt/Meta so Tmux and shell meta bindings work.
macos-option-as-alt = left
confirm-close-surface = false
copy-on-select = clipboard
mouse-hide-while-typing = true
shell-integration = zsh
shell-integration-features = cursor,sudo,title

# --- Quick terminal (global drop-down toggle) ---
# Press Ctrl+Esc anywhere to toggle a system-wide quick terminal.
# Requires granting Ghostty Accessibility permission for the global binding.
keybind = global:ctrl+escape=toggle_quick_terminal
quick-terminal-position = top
quick-terminal-animation-duration = 0
